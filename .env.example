# Boliga API
BOLIGA_ZIP=5800
BOLIGA_PROPERTY_TYPE=3
# cf_clearance cookie — hent fra DevTools: åbn api.boliga.dk i browser → F12 → Application → Cookies
BOLIGA_CF_CLEARANCE=

# Supabase (server-side, service role — ALDRIG eksponér til browser)
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cron-beskyttelse
CRON_SECRET=

# VAPID — generer med: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:nicklas-pedersen@outlook.com
